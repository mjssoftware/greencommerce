# Server
PORT=3008
NODE_ENV=production
API_VERSION=v1

# Database
MONGODB_URI=mongodb://localhost:27017/review_service
MONGODB_URI_TEST=mongodb://localhost:27017/review_service_test

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# JWT (for auth middleware)
JWT_SECRET=your-jwt-secret-key

# Service URLs
PRODUCT_SERVICE_URL=http://localhost:3002
ORDER_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_URL=http://localhost:3007

# Review Configuration
REVIEW_MODERATION_ENABLED=true
REVIEW_AUTO_APPROVE=false
MAX_IMAGES_PER_REVIEW=5
MAX_REVIEW_LENGTH=2000
MIN_REVIEW_LENGTH=10
REVIEW_HELPFUL_VOTES_LIMIT=100

# Rating Configuration
RATING_AVERAGE_DECIMALS=2
UPDATE_PRODUCT_RATING=true

# Sentiment Analysis
SENTIMENT_ANALYSIS_ENABLED=true
PROFANITY_FILTER_ENABLED=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# API Gateway
API_GATEWAY_URL=http://localhost:3000