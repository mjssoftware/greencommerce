# Server
PORT=3001
NODE_ENV=production
API_VERSION=v1

# Database
MONGODB_URI=mongodb://localhost:27017/auth_service
MONGODB_URI_TEST=mongodb://localhost:27017/auth_service_test

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SESSION_PREFIX=sess:

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=ecommerce-platform
JWT_AUDIENCE=ecommerce-api

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@ecommerce.com
FRONTEND_URL=http://localhost:3000

# Security
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Session
SESSION_SECRET=your-session-secret-key
SESSION_TTL=86400000

# Two-Factor Authentication (2FA)
TFA_APP_NAME=EcommercePlatform
TFA_ISSUER=Ecommerce

# Admin
ADMIN_EMAIL=admin@ecommerce.com
ADMIN_PASSWORD=Admin@123456

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# API Gateway
API_GATEWAY_URL=http://localhost:3000