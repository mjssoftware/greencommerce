# Server
PORT=3006
NODE_ENV=production
API_VERSION=v1

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CART_TTL=604800

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# JWT (for auth middleware)
JWT_SECRET=your-jwt-secret-key

# Service URLs
PRODUCT_SERVICE_URL=http://localhost:3002
INVENTORY_SERVICE_URL=http://localhost:3005

# Cart Configuration
CART_TTL_DAYS=7
MAX_CART_ITEMS=50
MAX_QUANTITY_PER_ITEM=99
GUEST_CART_TTL_HOURS=24

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# API Gateway
API_GATEWAY_URL=http://localhost:3000